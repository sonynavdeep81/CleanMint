#!/usr/bin/env bash
# cleanmint-helper — CleanMint Privileged Helper
# Installed to /usr/local/lib/cleanmint/cleanmint-helper
# Called exclusively via pkexec — runs as root with a single auth prompt.
# All CleanMint privileged operations go through this single entry point.
#
# Usage: pkexec /usr/local/lib/cleanmint/cleanmint-helper OPERATION [ARGS...]

set -e

OPERATION="${1:-}"
shift || true

case "$OPERATION" in
    journal-vacuum)
        exec /usr/bin/journalctl --vacuum-size=50M --vacuum-time=7d
        ;;
    apt-clean)
        exec /usr/bin/apt-get clean
        ;;
    apt-update)
        exec /usr/bin/apt-get update
        ;;
    apt-upgrade)
        exec /usr/bin/apt-get upgrade -y \
            -o "Dpkg::Options::=--force-confdef" \
            -o "Dpkg::Options::=--force-confold"
        ;;
    apt-upgrade-pkgs)
        # Args: <pkg1> <pkg2> ...
        [[ $# -ge 1 ]] || { echo "apt-upgrade-pkgs requires package names" >&2; exit 1; }
        exec /usr/bin/apt-get install --only-upgrade -y \
            -o "Dpkg::Options::=--force-confdef" \
            -o "Dpkg::Options::=--force-confold" "$@"
        ;;
    snap-remove)
        # Args: <name> <revision>
        [[ $# -ge 2 ]] || { echo "snap-remove requires <name> <revision>" >&2; exit 1; }
        exec /usr/bin/snap remove --revision "$2" "$1"
        ;;
    snap-refresh-all)
        exec /usr/bin/snap refresh
        ;;
    snap-refresh-pkg)
        # Args: <name>
        [[ $# -ge 1 ]] || { echo "snap-refresh-pkg requires <name>" >&2; exit 1; }
        exec /usr/bin/snap refresh "$1"
        ;;
    systemctl-restart)
        # Args: <service>
        [[ $# -ge 1 ]] || { echo "systemctl-restart requires <service>" >&2; exit 1; }
        exec /usr/bin/systemctl restart "$1"
        ;;
    apt-remove)
        # Args: <package>
        [[ $# -ge 1 ]] || { echo "apt-remove requires <package>" >&2; exit 1; }
        exec /usr/bin/apt-get remove -y "$1"
        ;;
    snap-uninstall)
        # Args: <name>  (removes all revisions)
        [[ $# -ge 1 ]] || { echo "snap-uninstall requires <name>" >&2; exit 1; }
        exec /usr/bin/snap remove "$1"
        ;;
    flatpak-uninstall)
        # Args: <app-id>
        [[ $# -ge 1 ]] || { echo "flatpak-uninstall requires <app-id>" >&2; exit 1; }
        exec /usr/bin/flatpak uninstall -y "$1"
        ;;
    *)
        echo "cleanmint-helper: unknown operation '${OPERATION}'" >&2
        echo "Valid: journal-vacuum, apt-clean, apt-update, apt-upgrade, apt-upgrade-pkgs," >&2
        echo "       snap-remove, snap-uninstall, apt-remove," >&2
        echo "       flatpak-uninstall, systemctl-restart" >&2
        exit 1
        ;;
esac
